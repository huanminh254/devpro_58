<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="6dp"
    android:layout_margin="10dp"
    android:background="@drawable/bg_round_item"
    android:elevation="3dp"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/img_constraint_layout"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#F8F8F8">

        <ImageView
            android:id="@+id/image_item_product"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:padding="12dp"
            android:background="@drawable/bg_img_item"
            android:scaleType="centerInside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <CheckBox
            android:id="@+id/heart_item_product"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:button="@null"
            android:background="@drawable/selector_heart"
            android:buttonTint="@null"
            app:buttonTint="@null"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_name_item_product"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_price_item_product"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#757575"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/option_item_product"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:background="@drawable/bg_round"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_tru"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/tru"
            android:background="@android:color/transparent"/>

        <TextView
            android:id="@+id/tv_quantity_item_product"
            android:layout_width="40dp"
            android:layout_height="30dp"
            android:text="0"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:background="@drawable/bg_round" />

        <ImageButton
            android:id="@+id/btn_cong"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/cong"
            android:background="@android:color/transparent"/>
    </LinearLayout>
</LinearLayout>